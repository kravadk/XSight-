# XSight server environment
# Copy to server/.env and fill in. NEVER commit the real .env.

PORT=8787
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# --- Anthropic Claude ---
# Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- OnchainOS / OKX DEX API ---
# Register at https://web3.okx.com/onchainos/dev-portal
# Connect wallet → create account → link email + phone → create project → generate API key
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
OKX_PROJECT_ID=

# --- Agentic Wallet (XSight project identity) ---
# AGENTIC_WALLET_ADDRESS must match the address derived from DEPLOYER_PRIVATE_KEY.
# Docs: https://web3.okx.com/onchainos/dev-docs/wallet/agentic-wallet
AGENTIC_WALLET_ADDRESS=

# Private key that signs swap transactions broadcast via X Layer RPC.
# WARNING: NEVER commit this. NEVER paste it in chat or share it anywhere.
# Use a dedicated wallet holding only funds you intend to trade with.
DEPLOYER_PRIVATE_KEY=

# X Layer RPC endpoint used for tx broadcast.
X_LAYER_RPC_URL=https://rpc.xlayer.tech

# --- x402 payments ---
# Address that receives x402 USDT payments on X Layer (zero gas)
X402_PAYOUT_ADDRESS=
X402_NETWORK=xlayer-mainnet
X402_ASSET=USDT

# Set to true to allow X-PAYMENT: dev-bypass in production (demo/hackathon builds)
ALLOW_DEV_BYPASS=true
